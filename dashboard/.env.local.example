# Robot Cell Monitor — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# -------------------------------------------------------------------
# MOCK MODE (no hardware required)
# Set to "true" to bypass the Viam SDK entirely and use simulated data.
# Faults fire automatically every ~15-20 seconds for demo purposes.
# Use the "Demo Controls" buttons on screen to trigger faults manually.
# -------------------------------------------------------------------
NEXT_PUBLIC_MOCK_MODE=true

# -------------------------------------------------------------------
# VIAM CLOUD CREDENTIALS (required when NEXT_PUBLIC_MOCK_MODE=false)
#
# Find these in the Viam app (app.viam.com):
#   1. Open your machine
#   2. Go to Connect tab > API Keys
#   3. Create a new API key with "Operator" role
#   4. Copy the Key ID and Key Value
#   5. Copy the machine address from the Connect tab
# -------------------------------------------------------------------

# The machine's cloud address (e.g. my-machine.xyz123abc.viam.cloud)
NEXT_PUBLIC_VIAM_MACHINE_ADDRESS=

# API Key ID (looks like: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
NEXT_PUBLIC_VIAM_API_KEY_ID=

# API Key value (long alphanumeric string)
NEXT_PUBLIC_VIAM_API_KEY=

# -------------------------------------------------------------------
# SECURITY NOTE
# These NEXT_PUBLIC_* variables are embedded in the browser bundle.
# For a POC this is acceptable. For production, proxy sensor reads
# through a Next.js API route so credentials stay server-side.
# -------------------------------------------------------------------
