# TPS Monitor Dashboard — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# -------------------------------------------------------------------
# MOCK MODE (no hardware required)
# Set to "true" to bypass the Viam SDK entirely and use simulated data.
# Faults fire automatically every ~15-20 seconds for demo purposes.
# -------------------------------------------------------------------
NEXT_PUBLIC_MOCK_MODE=true

# -------------------------------------------------------------------
# VIAM CLOUD CREDENTIALS (required when NEXT_PUBLIC_MOCK_MODE=false)
#
# Single-Pi architecture: one Pi 5 per truck runs all modules
# (plc-sensor, cell-sensor, j1939-sensor). One set of credentials.
#
# The Viam TypeScript SDK connects via WebRTC from the browser directly
# to the machine through Viam Cloud. These must be NEXT_PUBLIC_ prefixed
# so the browser can access them.
#
# For security, create a read-only API key with "Operator" role in the
# Viam app — this limits what the browser can do.
#
# Find these in the Viam app (app.viam.com):
#   1. Open your machine
#   2. Go to Connect tab → API Keys
#   3. Create a new API key with "Operator" role
#   4. Copy the Key ID and Key Value
#   5. Copy the machine address from the Connect tab
# -------------------------------------------------------------------

# The machine's cloud address (e.g. my-machine.xyz123abc.viam.cloud)
NEXT_PUBLIC_VIAM_MACHINE_ADDRESS=

# API Key ID (looks like: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
NEXT_PUBLIC_VIAM_API_KEY_ID=

# API Key value (long alphanumeric string)
NEXT_PUBLIC_VIAM_API_KEY=

# -------------------------------------------------------------------
# SERVER-SIDE CREDENTIALS (for API routes — NOT NEXT_PUBLIC_ prefixed)
#
# These are used by the server-side API routes to connect to Viam
# Cloud without exposing credentials to the browser.
# -------------------------------------------------------------------

# The machine's cloud address (same as above, without NEXT_PUBLIC_ prefix)
VIAM_MACHINE_ADDRESS=

# API Key ID (server-side)
VIAM_API_KEY_ID=

# API Key value (server-side)
VIAM_API_KEY=

# Machine Part ID for Data API historical queries
# Find this in /etc/viam.json on the Pi, or in the Viam app machine config
# This single Part ID is used for all components (plc-monitor, cell-monitor, truck-engine)
VIAM_PART_ID=

# -------------------------------------------------------------------
# AI DIAGNOSTIC ENGINE
# -------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------
# CLERK AUTHENTICATION
#
# Get these from https://dashboard.clerk.com after creating an app.
# Enable Google and Microsoft as social sign-in providers in the Clerk dashboard.
# -------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_SIGN_OUT_URL=/sign-in

# -------------------------------------------------------------------
# SUPABASE (server-side only — used for truck notes and assignments)
#
# Create a project at https://supabase.com, then find these in
# Project Settings → API. Use the service_role key (not anon).
# Run dashboard/supabase/schema.sql in the SQL editor to create tables.
# -------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------------------
# FLEET CONFIGURATION (optional — if not set, uses single-truck env vars above)
#
# JSON array of truck configs for multi-truck fleet support.
# Each entry maps a truck ID to its Viam Part ID and machine address.
# The org-level VIAM_API_KEY above is used for all data queries across the fleet.
#
# FLEET_TRUCKS=[{"id":"truck-01","name":"Truck 01","tpsPartId":"...","tpsMachineAddress":"..."}]
#
# Fields:
#   id              — Short identifier (used in ?truck_id= query param)
#   name            — Display name for the UI
#   tpsPartId       — Viam Part ID for the Pi 5 (all components on one machine)
#   tpsMachineAddress — (optional) Machine cloud address for commands
#
# When FLEET_TRUCKS is not set, a single-truck config is auto-constructed from
# VIAM_PART_ID and VIAM_MACHINE_ADDRESS above — full backward compatibility.
#
# API endpoints accept ?truck_id=<id> to target a specific truck.
# GET /api/fleet/trucks returns the configured truck list.
# -------------------------------------------------------------------
# FLEET_TRUCKS=

# -------------------------------------------------------------------
# FLEET SCALING NOTES
#
# For 30+ trucks, use an ORGANIZATION-level API key for data queries:
#   - VIAM_API_KEY / VIAM_API_KEY_ID: Org key with data read access
#   - This single key can query exportTabularData for ANY machine in the org
#
# Machine-level keys are only needed for direct commands
# (DTC clear, PGN requests) which require WebRTC to the specific machine.
#
# Part IDs: Each truck's Pi 5 has a unique Part ID in /etc/viam.json.
# The dashboard uses a truck registry mapping truck names to Part IDs.
# -------------------------------------------------------------------
