# IronSight Mobile — Environment Variables
# Copy to .env and fill in values from the web dashboard's .env.local
# See the web dashboard repo: ~/Viam-Staubli-Apera-PLC-Mobile-POC/dashboard/.env.local

# Clerk authentication — same publishable key as the web dashboard
# Get from: https://dashboard.clerk.com → Your App → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Supabase — use the ANON key, NOT the service role key
# Get from: https://supabase.com/dashboard → Project Settings → API → anon/public key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API base URL — the Vercel deployment that hosts the API routes
# Default: https://viam-staubli-apera-plc-mobile-poc.vercel.app
EXPO_PUBLIC_API_BASE_URL=
